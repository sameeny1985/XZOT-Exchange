# استفاده از نسخه پایدار و سبک نود جی‌اس بر پایه آیکونیک آلپاین
FROM node:18-alpine

# تعیین پوشه کاری پروژه در سرور
WORKDIR /app

# کپی کردن فایلهای کانفیگ پکیج‌ها
COPY package*.json ./

# نصب پکیج‌ها به صورت بهینه بدون فایلهای اضافی دِوِلوپر
RUN npm install --production

# کپی کردن کل کدهای صرافی (بک‌اند و پوشه public)
COPY . .

# باز کردن پورت سرور
EXPOSE 8080

# دستور نهایی برای روشن شدن سرور و ربات تلگرام
CMD ["npm", "start"]
